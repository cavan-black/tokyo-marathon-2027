# Copy to .env and fill in. One Strava API app (https://www.strava.com/settings/api)
# is shared; each runner authorises separately to get their own refresh token.
# Get each token by running:  python sync/get_token.py   (once per runner, that person logs in)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN_CAV=
STRAVA_REFRESH_TOKEN_JAMIE=
